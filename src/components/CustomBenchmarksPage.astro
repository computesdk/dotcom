---
---
<div class="isolate bg-transparent py-24">
  <div class="mx-auto max-w-2xl px-6 text-center lg:px-8">
    <span class="inline-flex items-center gap-1.5 bg-emerald-600/10 dark:bg-emerald-900/50 px-3 py-1 text-xs font-semibold text-emerald-700 dark:text-emerald-300 ring-1 ring-inset ring-emerald-600/20 rounded-full uppercase tracking-wider">
      <a href="/benchmarks" class="hover:text-emerald-500 dark:hover:text-emerald-200 transition-colors no-underline">Benchmarks</a>
      <svg class="size-2.5 shrink-0 opacity-60" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
      </svg>
      Custom Benchmarks
    </span>

    <h1 class="mt-6 text-balance text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl dark:text-white">Custom benchmarks to validate your product</h1>

    <p class="mt-6 text-lg/8 text-gray-600 dark:text-gray-300">
      Performance work is hard, is rarely marketed well, and self-reported numbers are easy to doubt. We'll write and run a custom benchmark against your infrastructure, independently verify your claims, and measure your reliability. Launch with performance data verified by an independent benchmark company.
    </p>

    <div class="mt-10 flex items-center justify-center gap-4">
      <a
        href="/sales"
        class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-500 transition-colors no-underline cursor-pointer"
      >
        Talk to our team
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
      <a
        href="/benchmarks/"
        class="inline-flex items-center gap-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 px-5 py-3 text-sm font-semibold text-gray-900 dark:text-white hover:border-gray-400 dark:hover:border-gray-500 transition-colors no-underline"
      >
        View our benchmarks
      </a>
    </div>

    <p class="mt-6 text-sm text-gray-500 dark:text-gray-400">
      Or email <a href="mailto:support@computesdk.com" class="text-emerald-600 dark:text-emerald-400 hover:underline no-underline">support@computesdk.com</a>
    </p>
  </div>
</div>

<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Benchmarks", "item": "https://www.computesdk.com/benchmarks" },
    { "@type": "ListItem", "position": 2, "name": "Custom Benchmarks", "item": "https://www.computesdk.com/custom-benchmarks" }
  ]
})} />
