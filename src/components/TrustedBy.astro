---
import SponsorLogos from "./SponsorLogos.astro"
---

<div class="py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:max-w-none text-center">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Trusted by the best
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">
        Independent benchmarks of every major sandbox provider, sponsored by industry leaders.
      </p>
      <div class="mt-10">
        <SponsorLogos tier="all" size="lg" layout="stacked" />
      </div>
      <div class="mt-8">
        <a 
          href="/benchmarks" 
          class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-600 dark:text-emerald-400 hover:text-emerald-700 dark:hover:text-emerald-300 no-underline transition-colors"
        >
          View full benchmarks
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>
