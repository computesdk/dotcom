---
import SponsorLogos from "./SponsorLogos.astro"

interface Props {
  displayName: string
}

const { displayName } = Astro.props
---

<div class="border border-gray-200 dark:border-gray-700 rounded-xl p-6 bg-linear-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-800">
  <div class="max-w-md mx-auto text-center">
    <div class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-amber-50 dark:bg-amber-900/20 text-xs font-medium text-amber-700 dark:text-amber-400 mb-3">
      <svg class="size-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
      Unverified profile
    </div>
    <h3 class="text-lg font-semibold text-gray-900 dark:text-white m-0 mb-2">
      Customize this profile
    </h3>
    <p class="text-xs max-w-xs mx-auto text-gray-500 dark:text-gray-400 m-0 mb-4">
      Add custom benchmarks, branding, links, & more to showcase what makes {displayName} unique.
    </p>
    <div>
      <a
        href="https://buy.stripe.com/5kQaEQ5oLdLpgVId8K5AQ02"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-gray-900 dark:bg-white text-white dark:text-gray-900 text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors no-underline"
      >
        Verify
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
    <div class="mt-6 pt-5 border-t border-gray-200/50 dark:border-gray-700/50">
      <SponsorLogos tier="tier-1" size="sm" layout="stacked" label="" />
    </div>
  </div>
</div>
