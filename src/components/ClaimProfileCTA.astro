---
interface Props {
  displayName: string
}

const { displayName } = Astro.props

const sponsors = [
  { name: "Daytona", logoLight: "/benchmarks/normal-daytona-light.svg", logoDark: "/benchmarks/normal-daytona-dark.svg", href: "/benchmarks/daytona" },
  { name: "E2B", logoLight: "/benchmarks/normal-e2b-light.svg", logoDark: "/benchmarks/normal-e2b-dark.svg", href: "/benchmarks/e2b" },
  { name: "Modal", logoLight: "/benchmarks/normal-modal-light.svg", logoDark: "/benchmarks/normal-modal-dark.svg", href: "/benchmarks/modal" },
]
---

<div class="border border-gray-200 dark:border-gray-700 rounded-xl p-6 bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-800">
  <div class="max-w-lg mx-auto text-center">
    <p class="text-sm text-gray-500 dark:text-gray-400 m-0 mb-4">
      This page is sponsored by
    </p>
    <div class="flex items-center justify-center gap-6 mb-5">
      {sponsors.map((s) => (
        <a href={s.href} class="opacity-60 hover:opacity-100 transition-opacity no-underline">
          <img src={s.logoLight} alt={s.name} class="h-5 w-auto object-contain dark:hidden" />
          <img src={s.logoDark} alt="" class="h-5 w-auto object-contain hidden dark:block" />
        </a>
      ))}
    </div>
    <p class="text-sm text-gray-900 dark:text-white font-medium m-0 mb-4">
      Is this you? Claim this page.
    </p>
    <a
      href="https://x.com/computesdk"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-gray-900 dark:bg-white text-white dark:text-gray-900 text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors no-underline"
    >
      Get started
      <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>
</div>
