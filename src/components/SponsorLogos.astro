---
interface Props {
  tier?: "all" | "tier-1"
  size?: "sm" | "md" | "lg"
  layout?: "inline" | "stacked"
  label?: string
}

const { tier = "all", size = "md", layout = "inline", label } = Astro.props

const allSponsors = [
  { 
    name: "Archil", 
    href: "https://archil.com/",
    logo: "/archil-logo.svg",
    tier: "tier-1"
  },
  { 
    name: "Latitude", 
    href: "https://latitude.so/",
    logo: "/latitude-logo.svg",
    tier: "tier-1"
  },
  { 
    name: "Browserbase", 
    href: "https://www.browserbase.com/",
    logo: "/browserbase-logo.svg",
    tier: "tier-2"
  },
  { 
    name: "Tigris", 
    href: "https://www.tigrisdata.com/",
    logo: "/tigris-logo.svg",
    tier: "tier-2"
  },
]

const sponsors = tier === "all" 
  ? allSponsors 
  : allSponsors.filter(s => s.tier === tier)

const sizeClasses = {
  sm: "h-6",
  md: "h-8", 
  lg: "h-10"
}

const gapClasses = {
  sm: "gap-6",
  md: "gap-8",
  lg: "gap-10"
}

const labelText = label || (layout === "stacked" ? "Backed by" : "Sponsored by")
---

{layout === "stacked" ? (
  <div class="flex flex-col items-center gap-6">
    <span class="text-sm font-medium text-gray-500 dark:text-gray-400">{labelText}</span>
    <div class={`flex items-center ${gapClasses[size]}`}>
      {sponsors.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">
          <img src={s.logo} alt={s.name} class={`${sizeClasses[size]} w-auto object-contain dark:invert`} />
        </a>
      ))}
    </div>
  </div>
) : (
  <div class="flex items-center gap-6">
    <span class="text-sm font-medium text-gray-500 dark:text-gray-400">{labelText}</span>
    <div class={`flex items-center ${gapClasses[size]}`}>
      {sponsors.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">
          <img src={s.logo} alt={s.name} class={`${sizeClasses[size]} w-auto object-contain dark:invert`} />
        </a>
      ))}
    </div>
  </div>
)}
