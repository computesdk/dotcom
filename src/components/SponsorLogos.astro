---
interface Props {
  tier?: "all" | "tier-1"
  size?: "sm" | "md" | "lg"
  layout?: "inline" | "stacked"
  align?: "left" | "center" | "right"
  label?: string
}

const { tier = "all", size = "md", layout = "inline", align = "center", label } = Astro.props

const allSponsors = [
  { 
    name: "Archil", 
    href: "https://archil.com/?utm_source=computesdk.com&utm_medium=referral&utm_campaign=sponsor-link",
    logo: "/archil-logo.svg",
    tier: "tier-1"
  },
  { 
    name: "Latitude", 
    href: "https://latitude.so/?utm_source=computesdk.com&utm_medium=referral&utm_campaign=sponsor-link",
    logo: "/latitude-logo.svg",
    tier: "tier-1"
  },
  { 
    name: "Browserbase", 
    href: "https://www.browserbase.com/?utm_source=computesdk.com&utm_medium=referral&utm_campaign=sponsor-link",
    logo: "/browserbase-logo.svg",
    tier: "tier-2"
  },
  { 
    name: "Tigris", 
    href: "https://www.tigrisdata.com/?utm_source=computesdk.com&utm_medium=referral&utm_campaign=sponsor-link",
    logo: "/tigris-logo.svg",
    tier: "tier-2"
  },
]

const sponsors = tier === "all" 
  ? allSponsors 
  : allSponsors.filter(s => s.tier === tier)

const sizeClasses = {
  sm: "h-6",
  md: "h-8", 
  lg: "h-10"
}

const gapClasses = {
  sm: "gap-6",
  md: "gap-8",
  lg: "gap-10"
}

const labelText = label || "Sponsored by"

const alignClasses = {
  left: "items-start",
  center: "items-center",
  right: "items-end",
}

const justifyClasses = {
  left: "justify-start",
  center: "justify-center",
  right: "justify-end",
}
---

{layout === "stacked" ? (
  <div class={`flex flex-col ${alignClasses[align]} gap-4 mt-0`}>
    <span class="text-sm font-medium text-gray-500 dark:text-gray-400">{labelText}</span>
    <div class={`flex items-center ${gapClasses[size]}`}>
      {sponsors.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">
          <img src={s.logo} alt={s.name} class={`${sizeClasses[size]} w-auto object-contain dark:invert`} />
        </a>
      ))}
    </div>
  </div>
) : (
  <div class={`flex items-center gap-6 mt-0 ${justifyClasses[align]}`}>
    <span class="text-sm font-medium text-gray-500 dark:text-gray-400">{labelText}</span>
    <div class={`flex items-center ${gapClasses[size]}`}>
      {sponsors.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">
          <img src={s.logo} alt={s.name} class={`${sizeClasses[size]} w-auto object-contain dark:invert`} />
        </a>
      ))}
    </div>
  </div>
)}
