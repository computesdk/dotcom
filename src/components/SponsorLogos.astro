---
interface Props {
  tier?: "all" | "tier-1"
  size?: "xs" | "sm" | "md" | "lg"
  layout?: "inline" | "stacked"
  align?: "left" | "center" | "right"
  mdAlign?: "left" | "center" | "right"
  label?: string
  exclude?: string
}

const { tier = "all", size = "md", layout = "inline", align = "center", mdAlign, label, exclude } = Astro.props

const allSponsors = [
  { 
    name: "Archil", 
    href: "https://archil.com/?utm_source=computesdk.com&utm_medium=referral&utm_campaign=sponsor-link",
    logo: "/archil-logo.svg",
    tier: "tier-1"
  },
  { 
    name: "Latitude", 
    href: "https://latitude.so/?utm_source=computesdk.com&utm_medium=referral&utm_campaign=sponsor-link",
    logo: "/latitude-logo.svg",
    tier: "tier-1"
  },
  { 
    name: "Browserbase", 
    href: "https://www.browserbase.com/?utm_source=computesdk.com&utm_medium=referral&utm_campaign=sponsor-link",
    logo: "/browserbase-logo.svg",
    tier: "tier-2"
  },
  { 
    name: "Tigris", 
    href: "https://www.tigrisdata.com/?utm_source=computesdk.com&utm_medium=referral&utm_campaign=sponsor-link",
    logo: "/tigris-logo.svg",
    tier: "tier-2"
  },
]

const excludeName = exclude?.toLowerCase()
const sponsors = (tier === "all" ? allSponsors : allSponsors.filter(s => s.tier === tier))
  .filter(s => excludeName ? s.name.toLowerCase() !== excludeName : true)

const sizeClasses = {
  xs: "h-4",
  sm: "h-6",
  md: "h-8", 
  lg: "h-10"
}

const gapClasses = {
  xs: "gap-4",
  sm: "gap-6",
  md: "gap-8",
  lg: "gap-10"
}

const labelText = label

const alignClasses = {
  left: "items-start",
  center: "items-center",
  right: "items-end",
}

const mdAlignClasses = {
  left: "md:items-start",
  center: "md:items-center",
  right: "md:items-end",
}

const justifyClasses = {
  left: "justify-start",
  center: "justify-center",
  right: "justify-end",
}

const mdJustifyClasses = {
  left: "md:justify-start",
  center: "md:justify-center",
  right: "md:justify-end",
}

const mdAlignStr = mdAlign ? mdAlignClasses[mdAlign] : ""
const mdJustifyStr = mdAlign ? mdJustifyClasses[mdAlign] : ""
---

{layout === "stacked" ? (
  <div class={`flex flex-col ${alignClasses[align]} ${mdAlignStr} gap-4 mt-0`}>
    <span class="text-xs font-medium text-gray-500 dark:text-gray-400">{labelText}</span>
    <div class={`flex items-center ${gapClasses[size]}`}>
      {sponsors.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">
          <img src={s.logo} alt={s.name} class={`${sizeClasses[size]} w-auto object-contain dark:invert`} />
        </a>
      ))}
    </div>
  </div>
) : (
  <div class={`flex items-center gap-6 mt-0 ${justifyClasses[align]} ${mdJustifyStr}`}>
    <span class="text-xs font-medium text-gray-500 dark:text-gray-400">{labelText}</span>
    <div class={`flex items-center ${gapClasses[size]}`}>
      {sponsors.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">
          <img src={s.logo} alt={s.name} class={`${sizeClasses[size]} w-auto object-contain dark:invert`} />
        </a>
      ))}
    </div>
  </div>
)}
