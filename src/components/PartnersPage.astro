---
import { SPONSORS, type Sponsor, type Tier } from "./benchmarks/sponsorData"

type TierDisplay = {
  key: Tier
  label: string
  lineColor: string
  textColor: string
  borderHover: string
  bgHover: string
  logoHeight: string
  logoMaxWidth: string
  cols: string
  cardPadding: string
}

const TIER_DISPLAY: TierDisplay[] = [
  {
    key: "gold",
    label: "★ GOLD",
    lineColor: "bg-[#b8860b]",
    textColor: "text-[#b8860b] dark:text-[#FFD700]",
    borderHover: "hover:border-yellow-400 dark:hover:border-yellow-600",
    bgHover: "hover:bg-yellow-50/50 dark:hover:bg-yellow-950/20",
    logoHeight: "h-12",
    logoMaxWidth: "max-w-40",
    cols: "sm:grid-cols-2",
    cardPadding: "p-4",
  },
  {
    key: "silver",
    label: "★ SILVER",
    lineColor: "bg-[#c0c0c0]",
    textColor: "text-[#6e7781] dark:text-[#c0c0c0]",
    borderHover: "hover:border-gray-400 dark:hover:border-gray-500",
    bgHover: "hover:bg-gray-50 dark:hover:bg-gray-800/50",
    logoHeight: "h-18",
    logoMaxWidth: "max-w-36",
    cols: "sm:grid-cols-2",
    cardPadding: "p-4",
  },
  {
    key: "bronze",
    label: "+ BRONZE",
    lineColor: "bg-[#cd7f32]",
    textColor: "text-[#854d22] dark:text-[#cd7f32]",
    borderHover: "hover:border-amber-500 dark:hover:border-amber-700",
    bgHover: "hover:bg-amber-50/50 dark:hover:bg-amber-950/20",
    logoHeight: "h-10",
    logoMaxWidth: "max-w-28",
    cols: "sm:grid-cols-2 lg:grid-cols-3",
    cardPadding: "p-4",
  },
  {
    key: "platform",
    label: "BENCHMARKS POWERED BY:",
    lineColor: "bg-emerald-600 dark:bg-emerald-400",
    textColor: "text-emerald-600 dark:text-emerald-400",
    borderHover: "hover:border-emerald-400 dark:hover:border-emerald-600",
    bgHover: "hover:bg-emerald-50/50 dark:hover:bg-emerald-950/20",
    logoHeight: "h-14",
    logoMaxWidth: "max-w-48",
    cols: "sm:grid-cols-2",
    cardPadding: "p-4",
  },
]

const TIERS = TIER_DISPLAY.map((tier) => ({
  ...tier,
  partners: SPONSORS.filter((s) => s.tier === tier.key) as Sponsor[],
}))
---

<div class="bg-white dark:bg-gray-950 min-h-screen">

  <!-- Hero -->
  <div class="border-b border-gray-200 dark:border-gray-800 py-8">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl font-semibold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Partners
      </h1>
      <p class="mt-6 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        ComputeSDK is made better by the companies and teams who partner with us.
      </p>
    </div>
  </div>

  <!-- Tiers -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-16 flex flex-col gap-16">
    {TIERS.filter((tier) => tier.partners.length > 0).map((tier) => (
      <div class="flex flex-col gap-6">

        <!-- Tier divider -->
        <div class="flex items-center gap-2">
          <div class={`h-px flex-1 ${tier.lineColor} opacity-60`} />
          <span class={`text-[10px] font-bold tracking-widest shrink-0 ${tier.textColor}`}>
            {tier.label}
          </span>
          <div class={`h-px flex-1 ${tier.lineColor} opacity-60`} />
        </div>

        <!-- Partner cards -->
        <div class={`grid grid-cols-1 gap-4 ${tier.cols}`}>
          {tier.partners.map((partner) => (
            <a
              href={partner.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`group flex items-center justify-center rounded-2xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900 ${tier.cardPadding} no-underline ${tier.borderHover} ${tier.bgHover} transition-all duration-200`}
            >
              <div class={`flex items-center justify-center ${tier.logoHeight} ${tier.logoMaxWidth} w-full`} style={partner.scale ? `transform: scale(${partner.scale})` : undefined}>
                <img src={partner.logo} alt={partner.name} loading="lazy" decoding="async" class="h-full w-full object-contain dark:hidden" />
                <img src={partner.logoDark} alt={partner.name} loading="lazy" decoding="async" class="h-full w-full object-contain hidden dark:block" />
              </div>
            </a>
          ))}
        </div>

      </div>
    ))}
  </div>

  <!-- CTA: Become a Partner -->
  <div class="border-t border-gray-200 dark:border-gray-800 py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl bg-gray-900 dark:bg-gray-800 px-8 py-16 sm:px-16 text-center ring-1 ring-gray-800 dark:ring-gray-700">
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Become a Partner
        </h2>
        <p class="mt-4 text-lg text-gray-300 max-w-2xl mx-auto">
          Partner with ComputeSDK to reach developers building AI agents, code execution platforms, and sandboxed applications. We'd love to explore how we can work together.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://docs.google.com/document/d/1M3Fh63ev6Qr4LLTS8eCtvmFasBo-TfYfMTCgx-h7ppw/edit?usp=sharing"
            target="_blank"
            class="inline-flex items-center rounded-lg bg-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:bg-emerald-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 no-underline transition-colors"
          >
            Learn more
          </a>
        </div>
      </div>
    </div>
  </div>

</div>
