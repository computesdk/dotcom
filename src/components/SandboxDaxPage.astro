---
import { SandboxDaxDashboard } from "./SandboxDaxDashboard";
import { fetchLatestDaxResults, fetchDaxHistoryData } from "../utils/benchmark-data";
import type { DaxResult, DaxHistoryPoint } from "./benchmarkConstants";
import Breadcrumbs from "./Breadcrumbs.astro";

const providerLogos: Record<string, string> = {
  e2b: "/benchmarks/normal-e2b-light.svg",
  vercel: "/benchmarks/normal-vercel-light.svg",
  blaxel: "/benchmarks/normal-blaxel-light.svg",
  modal: "/benchmarks/normal-modal-light.svg",
  daytona: "/benchmarks/normal-daytona-light.svg",
  northflank: "/benchmarks/normal-northflank-light.svg",
  namespace: "/benchmarks/normal-namespace-light.svg",
  hopx: "/benchmarks/normal-hopx-light.svg",
  codesandbox: "/benchmarks/normal-codesandbox-light.svg",
  runloop: "/benchmarks/normal-runloop-light.svg",
  justbash: "/benchmarks/normal-justbash-light.svg",
  "just-bash": "/benchmarks/normal-justbash-light.svg",
  cloudflare: "/benchmarks/normal-cloudflare-light.svg",
  archil: "/benchmarks/normal-archil-light.svg",
  upstash: "/benchmarks/normal-upstash-light.svg",
  declaw: "/benchmarks/normal-declaw-light.svg",
  tensorlake: "/benchmarks/normal-tensorlake-light.svg",
  isorun: "/benchmarks/normal-isorun-light.svg",
  beam: "/benchmarks/normal-beam-light.svg",
  createos: "/benchmarks/normal-createos-light.svg",
  superserve: "/benchmarks/normal-superserve-light.svg",
  tenki: "/benchmarks/normal-tenki-light.svg",
  lelantos: "/benchmarks/normal-lelantos-light.svg",
  "cloud-run": "/benchmarks/normal-google-cloud-run-light.svg",
  lightning: "/benchmarks/normal-lightning-ai-light.svg",
};

const providerLogosDark: Record<string, string> = {
  e2b: "/benchmarks/normal-e2b-dark.svg",
  vercel: "/benchmarks/normal-vercel-dark.svg",
  blaxel: "/benchmarks/normal-blaxel-dark.svg",
  modal: "/benchmarks/normal-modal-dark.svg",
  daytona: "/benchmarks/normal-daytona-dark.svg",
  northflank: "/benchmarks/normal-northflank-dark.svg",
  namespace: "/benchmarks/normal-namespace-dark.svg",
  hopx: "/benchmarks/normal-hopx-dark.svg",
  codesandbox: "/benchmarks/normal-codesandbox-dark.svg",
  runloop: "/benchmarks/normal-runloop-dark.svg",
  justbash: "/benchmarks/normal-justbash-dark.svg",
  "just-bash": "/benchmarks/normal-justbash-dark.svg",
  cloudflare: "/benchmarks/normal-cloudflare-dark.svg",
  archil: "/benchmarks/normal-archil-dark.svg",
  upstash: "/benchmarks/normal-upstash-dark.svg",
  declaw: "/benchmarks/normal-declaw-dark.svg",
  tensorlake: "/benchmarks/normal-tensorlake-dark.svg",
  isorun: "/benchmarks/normal-isorun-dark.svg",
  beam: "/benchmarks/normal-beam-dark.svg",
  createos: "/benchmarks/normal-createos-dark.svg",
  superserve: "/benchmarks/normal-superserve-dark.svg",
  tenki: "/benchmarks/normal-tenki-dark.svg",
  lelantos: "/benchmarks/normal-lelantos-dark.svg",
  "cloud-run": "/benchmarks/normal-google-cloud-run-dark.svg",
  lightning: "/benchmarks/normal-lightning-ai-dark.svg",
};

let fetchError = false;
let active: DaxResult[] = [];
let historyData: DaxHistoryPoint[] = [];
let timestamp = "";

try {
  const [results, historyResult] = await Promise.all([
    fetchLatestDaxResults(),
    fetchDaxHistoryData(),
  ]);
  active = results;
  historyData = historyResult.history;
  timestamp = historyResult.timestamp;
} catch {
  fetchError = true;
}

const daxData = { active, historyData, timestamp };
---

<div class="relative isolate bg-transparent dark:bg-transparent min-h-screen">
  <!-- Sticky header -->
  <header class="bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm sticky top-0 z-50">
    <div class="border-b border-gray-200/50 dark:border-gray-700/50">
      <div class="md:max-w-7xl md:mx-auto py-10 px-4 md:pb-12 md:pt-6 md:px-6">
        <Breadcrumbs items={[
          { label: "Benchmarks", href: "/benchmarks" },
          { label: "Sandbox Benchmarks", href: "/benchmarks/sandboxes" },
          { label: "Dax" },
        ]} />
        <div class="sm:flex sm:flex-row items-center md:justify-between gap-3">
          <div>
            <h1 class="text-3xl md:text-5xl font-semibold tracking-tight text-gray-900 dark:text-white">Dax Benchmark</h1>
            <p class="my-2 text-sm text-gray-700 dark:text-gray-400">A real-world workload benchmark inspired by <a href="https://x.com/thdxr/status/2077782888293040342" target="_blank">this tweet</a> from dax to test potential sandbox providers for OpenCode.</p>
          </div>
          <div class="m-0 text-left md:text-right">
            <div class="items-center">
              <a
                href="https://github.com/computesdk/benchmarks/blob/master/src/sandbox/dax.ts"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center h-8 gap-1.5 px-3 rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-100 hover:bg-gray-200 dark:bg-gray-800 dark:hover:bg-gray-700 text-xs md:text-sm font-medium text-gray-900 dark:text-white transition-all no-underline"
              >
                <svg class="size-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z" /></svg>
                View on Github
              </a>
            </div>
            {timestamp && (
              <a
              href="https://github.com/computesdk/benchmarks/blob/master/results/sandbox-dax/latest.json"
              target="_blank"
              >
                <span class="text-xs text-gray-700 dark:text-gray-400">Last run: {timestamp}</span>
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </header>

  {fetchError ? (
    <div class="max-w-4xl mx-auto my-0 py-16 text-center">
      <p class="text-gray-500 dark:text-gray-400">Benchmark data is currently unavailable. Please check back later.</p>
    </div>
  ) : (
    <div class="mt-0">
      <SandboxDaxDashboard
        client:only="react"
        data={daxData}
        providerLogos={providerLogos}
        providerLogosDark={providerLogosDark}
        currentBenchmark="dax"
      />

      <blockquote class="twitter-tweet" data-media-max-width="560" data-theme="light"><p lang="en" dir="ltr">if you think you have a good option run this<br><br>curl -fsSL <a href="https://t.co/sKj7k7aqWZ">https://t.co/sKj7k7aqWZ</a> | BENCH_PROVIDER=unknown BENCH_REGION=unknown bash</p>&mdash; dax (@thdxr) <a href="https://x.com/thdxr/status/2077987028344484167?ref_src=twsrc%5Etfw">July 17, 2026</a></blockquote> <script async src="https://platform.x.com/widgets.js" charset="utf-8"></script>

      <div class="md:max-w-7xl md:mx-auto px-4 md:px-6">
        <p class="text-center text-sm text-gray-600 dark:text-gray-400">
          Want to see a provider added?
        </p>
        <p class="text-center mt-1">
          <a href="https://x.com/computesdk" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2.5 bg-black dark:bg-white text-white dark:text-black text-sm font-medium rounded-full hover:bg-gray-800 dark:hover:bg-gray-200 transition-colors">
            Let us know on X
            <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 3h6v6M10 14L21 3M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
            </svg>
          </a>
        </p>
      </div>
    </div>
  )}

  <!-- Methodology -->
  <div id="methodology" class="md:max-w-7xl md:mx-auto px-4 md:px-6 py-6 scroll-mt-16">
    <h2 class="text-base text-md font-semibold text-gray-900 dark:text-white mb-6">Methodology</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-10">
      <div class="mt-0">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">What We Measure</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-3">
          Each run executes a cold <strong class="text-gray-900 dark:text-white">clone + install + typecheck</strong> cycle of the opencode repository inside a fresh sandbox: install system packages and Node.js, download and unpack Bun, shallow-clone opencode at a pinned commit, run <code class="bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded text-[11px]">bun install</code>, then <code class="bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded text-[11px]">bun typecheck</code>.
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
          Each provider runs <strong class="text-gray-900 dark:text-white">3 iterations</strong> per benchmark run. Benchmarks run via GitHub Actions and results are committed to the <a href="https://github.com/computesdk/benchmarks" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 hover:text-gray-900 dark:hover:text-white transition-colors">public benchmarks repo</a>.
        </p>
      </div>

      <div class="mt-0">
        <h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">How We Score</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-3">
          The <strong class="text-gray-900 dark:text-white">Composite Score</strong> is the median number of the 7 benchmark phases (prepare, cache clear, bun download, bun unpack, clone, install, typecheck) a provider completed before failing, if any — shown as a fraction like <strong class="text-gray-900 dark:text-white">7/7</strong>.
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
          The other metrics (Total, Prepare, Clone, Install, Typecheck) are real-world phase durations in seconds — providers are ranked by <strong class="text-gray-900 dark:text-white">median duration</strong> (lower is better) when one of those is selected. The benchmark requires curl, root/sudo, and apt-get inside the sandbox — providers without those capabilities fail early, which shows up as a low phase count.
        </p>
      </div>
    </div>
  </div>
</div>
