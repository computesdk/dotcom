---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro"
import PageLayout from "../../components/layouts/PageLayout.astro"
import Footer from "../../components/Footer.astro"
import ClaimProfileCTA from "../../components/ClaimProfileCTA.astro"
import { ProviderDetailDashboard } from "../../components/ProviderDetailDashboard"
import { capitalize } from "../../components/benchmarkConstants"
import type { ProviderResult, HistoryDataPoint } from "../../components/benchmarkConstants"

interface TestTypeData {
  active: ProviderResult[]
  historyData: HistoryDataPoint[]
  timestamp: string
}

const TEST_TYPES = ["sequential_tti", "burst_tti", "staggered_tti"] as const
const BASE_URL = "https://raw.githubusercontent.com/computesdk/benchmarks/refs/heads/master/results"
const API_URL = "https://api.github.com/repos/computesdk/benchmarks/contents/results"
const cutoffDate = new Date("2026-02-23T00:00:00Z")
const excludedProviders = new Set(["railway", "render"])
const HISTORY_BATCH_SIZE = 10

const githubHeaders: Record<string, string> = {
  Accept: "application/vnd.github.v3+json",
}
const githubToken = import.meta.env.GITHUB_TOKEN
if (githubToken) {
  githubHeaders["Authorization"] = `Bearer ${githubToken}`
}

const providerLogos: Record<string, string> = {
  e2b: "/benchmarks/normal-e2b-light.svg",
  vercel: "/benchmarks/normal-vercel-light.svg",
  blaxel: "/benchmarks/normal-blaxel-light.svg",
  modal: "/benchmarks/normal-modal-light.svg",
  daytona: "/benchmarks/normal-daytona-light.svg",
  namespace: "/benchmarks/normal-namespace-light.svg",
  hopx: "/benchmarks/normal-hopx-light.svg",
  codesandbox: "/benchmarks/normal-codesandbox-light.svg",
  runloop: "/benchmarks/normal-runloop-light.svg",
  justbash: "/benchmarks/normal-justbash-light.svg",
  "just-bash": "/benchmarks/normal-justbash-light.svg",
  cloudflare: "/benchmarks/normal-cloudflare-light.svg",
}

const providerLogosDark: Record<string, string> = {
  e2b: "/benchmarks/normal-e2b-dark.svg",
  vercel: "/benchmarks/normal-vercel-dark.svg",
  blaxel: "/benchmarks/normal-blaxel-dark.svg",
  modal: "/benchmarks/normal-modal-dark.svg",
  daytona: "/benchmarks/normal-daytona-dark.svg",
  namespace: "/benchmarks/normal-namespace-dark.svg",
  hopx: "/benchmarks/normal-hopx-dark.svg",
  codesandbox: "/benchmarks/normal-codesandbox-dark.svg",
  runloop: "/benchmarks/normal-runloop-dark.svg",
  justbash: "/benchmarks/normal-justbash-dark.svg",
  "just-bash": "/benchmarks/normal-justbash-dark.svg",
  cloudflare: "/benchmarks/normal-cloudflare-dark.svg",
}

export async function getStaticPaths() {
  const excludedSet = new Set(["railway", "render"])
  try {
    const res = await fetch("https://raw.githubusercontent.com/computesdk/benchmarks/refs/heads/master/results/sequential_tti/latest.json")
    if (!res.ok) return []
    const data = await res.json()
    const providers = data.results
      .filter((r: any) => !r.skipped && !excludedSet.has(r.provider) && r.summary?.ttiMs?.median != null && r.summary.ttiMs.median > 0)
      .map((r: any) => r.provider)
    return providers.map((provider: string) => ({
      params: { provider },
      props: { provider },
    }))
  } catch {
    return []
  }
}

const { provider } = Astro.props as { provider: string }

let fetchError = false
const datasets: Record<string, TestTypeData> = {}
let allProviders: ProviderResult[] = []
let providerRank = 0
let totalProviders = 0

async function fetchTestType(testType: string): Promise<TestTypeData> {
  const data: TestTypeData = { active: [], historyData: [], timestamp: "" }

  const res = await fetch(`${BASE_URL}/${testType}/latest.json`)
  if (!res.ok) throw new Error(`HTTP ${res.status}`)
  const benchmarkData = await res.json()
  const results = benchmarkData.results as ProviderResult[]
  data.timestamp = new Date(benchmarkData.timestamp).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  })
  data.active = results
    .filter((r) => !r.skipped && !excludedProviders.has(r.provider) && r.summary?.ttiMs?.median != null && r.summary.ttiMs.median > 0)
    .sort((a, b) => a.summary.ttiMs.median - b.summary.ttiMs.median)

  try {
    const listRes = await fetch(`${API_URL}/${testType}`, { headers: githubHeaders })
    if (listRes.ok) {
      const files = (await listRes.json()) as Array<{ name: string; download_url: string }>
      const jsonFiles = files
        .filter((f) => f.name.endsWith(".json") && f.name !== "latest.json" && f.name !== ".gitkeep")
        .sort((a, b) => a.name.localeCompare(b.name))

      const historyPoints: HistoryDataPoint[] = []

      for (let i = 0; i < jsonFiles.length; i += HISTORY_BATCH_SIZE) {
        const batch = jsonFiles.slice(i, i + HISTORY_BATCH_SIZE)
        const batchResults = await Promise.all(
          batch.map(async (file) => {
            try {
              const fileRes = await fetch(file.download_url)
              if (!fileRes.ok) return null
              return await fileRes.json()
            } catch {
              return null
            }
          })
        )

        for (const fileData of batchResults) {
          if (!fileData) continue
          const ts = fileData.timestamp as string
          if (new Date(ts) <= cutoffDate) continue
          const dateLabel = new Date(ts).toLocaleDateString("en-US", { month: "short", day: "numeric" })
          const point: HistoryDataPoint = { date: dateLabel }
          for (const r of fileData.results as ProviderResult[]) {
            if (r.provider === provider && !r.skipped && r.summary?.ttiMs?.median != null && r.summary.ttiMs.median > 0) {
              const t = r.summary.ttiMs
              point[`${r.provider}_median`] = Math.round(t.median)
              point[`${r.provider}_p95`] = Math.round(t.p95)
              point[`${r.provider}_p99`] = Math.round(t.p99)
              const ceil = 10_000
              const score = (v: number) => Math.max(0, 100 * (1 - v / ceil))
              const weighted = score(t.median) * 0.6 + score(t.p95) * 0.25 + score(t.p99) * 0.15
              const sr = r.successRate ?? 1
              point[`${r.provider}_compositeScore`] = Math.round(weighted * sr * 10) / 10
              point[r.provider] = Math.round(t.median)
            }
          }
          if (Object.keys(point).length > 1) {
            historyPoints.push(point)
          }
        }
      }

      data.historyData = historyPoints
    }
  } catch {
    // History fetch failed
  }

  return data
}

try {
  const results = await Promise.all(TEST_TYPES.map((t) => fetchTestType(t)))
  for (let i = 0; i < TEST_TYPES.length; i++) {
    datasets[TEST_TYPES[i]] = results[i]
  }
  allProviders = datasets.sequential_tti?.active || []
  totalProviders = allProviders.length
  const rankIndex = allProviders.findIndex((r) => r.provider === provider)
  providerRank = rankIndex >= 0 ? rankIndex + 1 : 0
} catch (e) {
  fetchError = true
}

const providerData: Record<string, ProviderResult | null> = {}
for (const testType of TEST_TYPES) {
  const d = datasets[testType]
  providerData[testType] = d?.active.find((r) => r.provider === provider) || null
}

const displayName = capitalize(provider)
---

<StarlightPage
  frontmatter={{
    title: `${displayName} Sandbox Benchmarks`,
    description: `Detailed benchmark results and performance data for ${displayName} sandbox provider on ComputeSDK.`,
    template: "splash",
  }}
>
  <PageLayout>
    <div class="relative isolate bg-transparent dark:bg-transparent min-h-screen">
      <header class="bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm">
        <div class="border-b border-gray-200/50 dark:border-gray-700/50">
          <div class="md:max-w-7xl md:mx-auto py-8 px-4 md:py-10 md:px-6">
            <div class="mb-4">
              <a
                href="/benchmarks"
                class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors no-underline"
              >
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                </svg>
                Back to Leaderboard
              </a>
            </div>

            <div class="flex items-center gap-4">
              {providerLogos[provider] && (
                <>
                  <img src={providerLogos[provider]} alt={`${displayName} logo`} class="h-8 w-auto object-contain dark:hidden" />
                  <img src={providerLogosDark[provider] || providerLogos[provider]} alt="" class="h-8 w-auto object-contain hidden dark:block" />
                </>
              )}
              {!providerLogos[provider] && (
                <h1 class="text-xl md:text-3xl font-semibold tracking-tight text-gray-900 dark:text-white m-0">
                  {displayName}
                </h1>
              )}
            </div>

            <div class="mt-3 flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
              {providerRank > 0 && (
                <span>
                  Ranked <span class="font-semibold text-gray-900 dark:text-white">#{providerRank}</span> of {totalProviders} providers
                </span>
              )}
              {datasets.sequential_tti?.timestamp && (
                <span>Last benchmarked {datasets.sequential_tti.timestamp}</span>
              )}
            </div>
          </div>
        </div>
      </header>

      <!-- Claim CTA banner -->
      <div class="md:max-w-7xl md:mx-auto px-4 md:px-6 pt-6">
        <ClaimProfileCTA displayName={displayName} />
      </div>

      <!-- Verified benchmark data -->
      {fetchError ? (
        <div class="max-w-4xl mx-auto my-0 py-16 text-center">
          <p class="text-gray-500 dark:text-gray-400">Benchmark data is currently unavailable. Please check back later.</p>
        </div>
      ) : (
        <ProviderDetailDashboard
          client:visible
          provider={provider}
          providerData={providerData}
          datasets={datasets}
          providerRank={providerRank}
          totalProviders={totalProviders}
        />
      )}

      <!-- Claim CTA (bottom) -->
      <div class="md:max-w-7xl md:mx-auto px-4 md:px-6 pb-8">
        <div class="flex items-center gap-4 py-6">
          <div class="flex-1 h-px bg-gray-200 dark:bg-gray-700" />
        </div>
        <ClaimProfileCTA displayName={displayName} />
      </div>
    </div>
  </PageLayout>
  <Footer />
</StarlightPage>

<style is:global>
  .nova-page-frame-header {
    position: relative !important;
  }
  .main-frame {
    padding-top: 0 !important;
  }
</style>
