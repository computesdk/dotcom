---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import PageLayout from "../../../../components/layouts/PageLayout.astro";
import { AIGatewayProviderDetailDashboard } from "../../../../components/AIGatewayProviderDetailDashboard";
import { capitalize, isAIGatewayBaseline } from "../../../../components/benchmarkConstants";
import Breadcrumbs from "../../../../components/Breadcrumbs.astro";
import type { AIGatewayResult, AIGatewayHistoryPoint } from "../../../../components/benchmarkConstants";
import { fetchGithubDirectoryListing, fetchGithubFile } from "../../../../utils/github-history";

const BASE_URL = "https://raw.githubusercontent.com/computesdk/benchmarks/refs/heads/master/results";
const API_URL = "https://api.github.com/repos/computesdk/benchmarks/contents/results";
const HISTORY_BATCH_SIZE = 10;

const LOGO_API = "https://logos.computesdk.com/api/svg";
const logoUrl = (brandId: string, variant: "logo-light" | "logo-dark") =>
  `${LOGO_API}/${brandId}/normalized/${variant}`;

const providerLogos: Record<string, string> = {
  openrouter: logoUrl("openrouter", "logo-light"),
  "vercel-ai-gateway": logoUrl("vercel", "logo-light"),
  "cloudflare-ai-gateway": logoUrl("cloudflare", "logo-light"),
  llmgateway: logoUrl("llm-gateway", "logo-light"),
  "pydantic-ai-gateway": logoUrl("pydantic", "logo-light"),
  "anthropic-direct": logoUrl("anthropic", "logo-light"),
};

const providerLogosDark: Record<string, string> = {
  openrouter: logoUrl("openrouter", "logo-dark"),
  "vercel-ai-gateway": logoUrl("vercel", "logo-dark"),
  "cloudflare-ai-gateway": logoUrl("cloudflare", "logo-dark"),
  llmgateway: logoUrl("llm-gateway", "logo-dark"),
  "pydantic-ai-gateway": logoUrl("pydantic", "logo-dark"),
  "anthropic-direct": logoUrl("anthropic", "logo-dark"),
};

export async function getStaticPaths() {
  try {
    const BASE = "https://raw.githubusercontent.com/computesdk/benchmarks/refs/heads/master/results";
    const res = await fetch(`${BASE}/ai-gateway/latest.json`);
    if (!res.ok) return [];
    const data = await res.json();
    const providers = (data.results as AIGatewayResult[])
      .filter((r) => !r.skipped && r.summary?.coldE2eMs?.median != null)
      .map((r) => r.provider);
    return providers.map((provider: string) => ({
      params: { provider },
      props: { provider },
    }));
  } catch {
    return [];
  }
}

const { provider } = Astro.props as { provider: string };

const githubHeaders: Record<string, string> = {
  Accept: "application/vnd.github.v3+json",
};
const githubToken = import.meta.env.GITHUB_TOKEN;
if (githubToken) {
  githubHeaders["Authorization"] = `Bearer ${githubToken}`;
}

let fetchError = false;
let result: AIGatewayResult | null = null;
let allResults: AIGatewayResult[] = [];
let historyData: AIGatewayHistoryPoint[] = [];
let timestamp = "";

try {
  const res = await fetch(`${BASE_URL}/ai-gateway/latest.json`);
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const data = await res.json();
  timestamp = new Date(data.timestamp).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

  allResults = (data.results as AIGatewayResult[])
    .filter((r) => !r.skipped && r.summary?.coldE2eMs?.median != null)
    .sort((a, b) => (b.compositeScore ?? 0) - (a.compositeScore ?? 0));

  result = allResults.find((r) => r.provider === provider) || null;

  // Fetch history
  const files = await fetchGithubDirectoryListing(`${API_URL}/ai-gateway`, githubHeaders);
  if (files.length) {
    const jsonFiles = files
      .filter((f) => f.name.endsWith(".json") && f.name !== "latest.json" && f.name !== ".gitkeep")
      .sort((a, b) => a.name.localeCompare(b.name));

    for (let i = 0; i < jsonFiles.length; i += HISTORY_BATCH_SIZE) {
      const batch = jsonFiles.slice(i, i + HISTORY_BATCH_SIZE);
      const batchResults = await Promise.all(
        batch.map((file) => fetchGithubFile(file.download_url))
      );

      for (const fileData of batchResults) {
        if (!fileData) continue;
        const ts = fileData.timestamp as string;
        const dateLabel = new Date(ts).toLocaleDateString("en-US", { month: "short", day: "numeric" });
        const point: AIGatewayHistoryPoint = { date: dateLabel };
        for (const r of fileData.results as AIGatewayResult[]) {
          if (r.provider === provider && !r.skipped && r.summary?.coldE2eMs?.median != null) {
            point[`${r.provider}_coldE2eMs`] = Math.round(r.summary.coldE2eMs.median);
            point[`${r.provider}_warmTtftMs`] = Math.round(r.summary.warmTtftMs.median);
            point[`${r.provider}_outputTokensPerSec`] = Math.round(r.summary.outputTokensPerSec.median * 10) / 10;
            point[`${r.provider}_dnsMs`] = Math.round(r.summary.dnsMs.median * 10) / 10;
            point[`${r.provider}_tcpMs`] = Math.round(r.summary.tcpMs.median * 10) / 10;
            point[`${r.provider}_tlsMs`] = Math.round(r.summary.tlsMs.median * 10) / 10;
            if (r.compositeScore != null) {
              point[`${r.provider}_compositeScore`] = r.compositeScore;
            }
          }
        }
        if (Object.keys(point).length > 1) {
          historyData.push(point);
        }
      }
    }
  }
} catch {
  fetchError = true;
}

const displayName = capitalize(provider);
const baseline = isAIGatewayBaseline(provider);
---

<StarlightPage
  frontmatter={{
    title: `${displayName} AI Gateway Benchmarks`,
    description: `Detailed AI gateway benchmark results for ${displayName} — cold and warm connection latency, streaming throughput, and historical performance.`,
    template: "splash",
    head: [
      { tag: "link", attrs: { rel: "canonical", href: `https://www.computesdk.com/benchmarks/ai-gateway/${provider}/` } },
      { tag: "meta", attrs: { property: "og:image", content: `https://www.computesdk.com/benchmarks/ai-gateway/og/${provider}.png` } },
      { tag: "meta", attrs: { property: "og:url", content: `https://www.computesdk.com/benchmarks/ai-gateway/${provider}/` } },
      { tag: "meta", attrs: { property: "og:type", content: "website" } },
      { tag: "meta", attrs: { name: "twitter:card", content: "summary_large_image" } },
      { tag: "meta", attrs: { name: "twitter:image", content: `https://www.computesdk.com/benchmarks/ai-gateway/og/${provider}.png` } },
    ],
  }}
>
  <PageLayout>
  <div class="relative isolate bg-transparent dark:bg-transparent min-h-screen">

    <header class="bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm">
      <div class="border-b border-gray-200/50 dark:border-gray-700/50">

        <!-- Provider hero -->
        <div class="md:max-w-7xl md:mx-auto mt-0 py-8 px-4 md:py-10 md:px-6">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
              <Breadcrumbs items={[
                { label: "Benchmarks", href: "/benchmarks" },
                { label: "AI Gateway Benchmarks", href: "/benchmarks/ai-gateway" },
                { label: displayName },
              ]} />
              <h1 class="text-xl md:text-3xl font-semibold tracking-tight text-gray-900 dark:text-white m-0">
                {providerLogos[provider] ? (
                  <div class="flex flex-col gap-3">
                    <div class="flex items-center gap-4">
                      <img src={providerLogos[provider]} alt={displayName} class="h-8 w-auto object-contain dark:hidden" />
                      <img src={providerLogosDark[provider] || providerLogos[provider]} alt="" class="h-8 w-auto mt-0 object-contain hidden dark:block" />
                    </div>
                    <span class="text-lg md:text-2xl">AI Gateway Benchmarks</span>
                  </div>
                ) : (
                  <>{displayName} AI Gateway Benchmarks</>
                )}
              </h1>
              {timestamp && (
                <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">Last benchmarked {timestamp}</p>
              )}
              {baseline && (
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                  No-gateway control — a direct call to Anthropic's API, used to measure how much latency each gateway adds.
                </p>
              )}
            </div>
          </div>
        </div>
      </div>
    </header>

    {fetchError || !result ? (
      <div class="max-w-4xl mx-auto my-0 py-16 text-center">
        <p class="text-gray-500 dark:text-gray-400">Benchmark data is currently unavailable. Please check back later.</p>
      </div>
    ) : (
      <AIGatewayProviderDetailDashboard
        client:visible
        provider={provider}
        result={result}
        historyData={historyData}
      />
    )}

  </div>
  </PageLayout>
</StarlightPage>

<style is:global>
  .provider-nav-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .provider-nav-scroll::-webkit-scrollbar {
    display: none;
  }
</style>
