---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import PageLayout from "../../../../components/layouts/PageLayout.astro";
import SponsorLogos from "../../../../components/SponsorLogos.astro";
import { StorageProviderDetailDashboard } from "../../../../components/StorageProviderDetailDashboard";
import { capitalize } from "../../../../components/benchmarkConstants";
import type { StorageResult, StorageHistoryPoint } from "../../../../components/benchmarkConstants";

const FILE_SIZE = "10mb";
const BASE_URL = "https://raw.githubusercontent.com/computesdk/benchmarks/refs/heads/master/results";
const API_URL = "https://api.github.com/repos/computesdk/benchmarks/contents/results";
const HISTORY_BATCH_SIZE = 10;

const providerLogos: Record<string, string> = {
  "aws-s3": "/benchmarks/normal-aws-s3-light.svg",
  "cloudflare-r2": "/benchmarks/normal-cloudflare-light.svg",
  "tigris": "/benchmarks/normal-tigris-light.svg",
};

const providerLogosDark: Record<string, string> = {
  "aws-s3": "/benchmarks/normal-aws-s3-dark.svg",
  "cloudflare-r2": "/benchmarks/normal-cloudflare-dark.svg",
  "tigris": "/benchmarks/normal-tigris-dark.svg",
};

export async function getStaticPaths() {
  try {
    const BASE = "https://raw.githubusercontent.com/computesdk/benchmarks/refs/heads/master/results";
    const res = await fetch(`${BASE}/storage/10mb/latest.json`);
    if (!res.ok) return [];
    const data = await res.json();
    const providers = (data.results as StorageResult[])
      .filter((r) => !r.skipped && r.summary?.uploadMs?.median != null && r.summary.uploadMs.median > 0)
      .map((r) => r.provider);
    return providers.map((provider: string) => ({
      params: { provider },
      props: { provider },
    }));
  } catch {
    return [];
  }
}

const { provider } = Astro.props as { provider: string };

const githubHeaders: Record<string, string> = {
  Accept: "application/vnd.github.v3+json",
};
const githubToken = import.meta.env.GITHUB_TOKEN;
if (githubToken) {
  githubHeaders["Authorization"] = `Bearer ${githubToken}`;
}

let fetchError = false;
let result: StorageResult | null = null;
let allResults: StorageResult[] = [];
let historyData: StorageHistoryPoint[] = [];
let timestamp = "";

try {
  const res = await fetch(`${BASE_URL}/storage/${FILE_SIZE}/latest.json`);
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const data = await res.json();
  timestamp = new Date(data.timestamp).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

  allResults = (data.results as StorageResult[])
    .filter((r) => !r.skipped && r.summary?.uploadMs?.median != null && r.summary.uploadMs.median > 0)
    .sort((a, b) => (b.compositeScore ?? 0) - (a.compositeScore ?? 0));

  result = allResults.find((r) => r.provider === provider) || null;

  // Fetch history
  const listRes = await fetch(`${API_URL}/storage/${FILE_SIZE}`, { headers: githubHeaders });
  if (listRes.ok) {
    const files = (await listRes.json()) as Array<{ name: string; download_url: string }>;
    const jsonFiles = files
      .filter((f) => f.name.endsWith(".json") && f.name !== "latest.json" && f.name !== ".gitkeep")
      .sort((a, b) => a.name.localeCompare(b.name));

    for (let i = 0; i < jsonFiles.length; i += HISTORY_BATCH_SIZE) {
      const batch = jsonFiles.slice(i, i + HISTORY_BATCH_SIZE);
      const batchResults = await Promise.all(
        batch.map(async (file) => {
          try {
            const fileRes = await fetch(file.download_url);
            if (!fileRes.ok) return null;
            return await fileRes.json();
          } catch {
            return null;
          }
        })
      );

      for (const fileData of batchResults) {
        if (!fileData) continue;
        const ts = fileData.timestamp as string;
        const dateLabel = new Date(ts).toLocaleDateString("en-US", { month: "short", day: "numeric" });
        const point: StorageHistoryPoint = { date: dateLabel };
        for (const r of fileData.results as StorageResult[]) {
          if (r.provider === provider && !r.skipped && r.summary?.uploadMs?.median != null) {
            point[`${r.provider}_uploadMs`] = Math.round(r.summary.uploadMs.median);
            point[`${r.provider}_downloadMs`] = Math.round(r.summary.downloadMs.median);
            point[`${r.provider}_throughputMbps`] = Math.round(r.summary.throughputMbps.median * 10) / 10;
            if (r.compositeScore != null) {
              point[`${r.provider}_compositeScore`] = r.compositeScore;
            }
          }
        }
        if (Object.keys(point).length > 1) {
          historyData.push(point);
        }
      }
    }
  }
} catch {
  fetchError = true;
}

const displayName = capitalize(provider);
---

<StarlightPage
  frontmatter={{
    title: `${displayName} Storage Benchmarks`,
    description: `Detailed storage benchmark results for ${displayName} — upload/download latency, throughput, and historical performance.`,
    template: "splash",
  }}
>
  <PageLayout>
  <div class="relative isolate bg-transparent dark:bg-transparent min-h-screen">

    <header class="bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm">
      <div class="border-b border-gray-200/50 dark:border-gray-700/50">

        <!-- Provider nav strip -->
        {allResults.length > 0 && (
          <div class="border-b mt-0 border-gray-200/50 dark:border-gray-700/50 bg-white/30 dark:bg-gray-900/30">
            <div class="md:max-w-7xl md:mx-auto relative">
              <div class="flex px-4 md:px-6 py-4 gap-2 overflow-x-auto provider-nav-scroll" id="provider-nav">
                <a
                  href="/benchmarks/storage"
                  class="shrink-0 inline-flex flex-col items-center justify-center gap-1 px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white/50 dark:bg-gray-800/50 hover:border-gray-300 dark:hover:border-gray-600 hover:shadow-lg text-sm no-underline transition-all"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 dark:text-gray-500"><path d="m15 18-6-6 6-6"/></svg>
                  <span class="text-xs font-medium text-gray-500 dark:text-gray-400">All</span>
                </a>
                {allResults.map((p) => {
                  const isCurrent = p.provider === provider;
                  const pName = capitalize(p.provider);
                  // aws-s3 → s3, cloudflare-r2 → cloudflare, tigris → tigris
                  const logomarkKey = p.provider === "aws-s3" ? "s3" : p.provider === "cloudflare-r2" ? "cloudflare" : p.provider;
                  const logomarkLight = `/benchmarks/${logomarkKey}-logomark-light.svg`;
                  const logomarkDark = `/benchmarks/${logomarkKey}-logomark-dark.svg`;
                  return (
                    <a
                      href={`/benchmarks/storage/${p.provider}`}
                      class:list={[
                        "shrink-0 min-w-28 inline-flex flex-col items-center gap-1 py-2 px-3 rounded-lg border text-sm no-underline transition-all",
                        isCurrent
                          ? "border-gray-900 dark:border-white bg-white dark:bg-gray-800 shadow-lg"
                          : "border-gray-200 dark:border-gray-700 bg-white/50 dark:bg-gray-800/50 hover:border-gray-300 dark:hover:border-gray-600 hover:shadow-lg",
                      ]}
                    >
                      <img src={logomarkLight} alt={`${pName} logo`} class="h-5 w-5 object-contain dark:hidden" />
                      <img src={logomarkDark} alt="" class="h-5 w-5 object-contain hidden dark:block" />
                      <span class:list={["text-xs font-medium", isCurrent ? "text-gray-900 dark:text-white" : "text-gray-500 dark:text-gray-400"]}>{pName}</span>
                    </a>
                  );
                })}
              </div>
            </div>
          </div>
        )}

        <!-- Provider hero -->
        <div class="md:max-w-7xl md:mx-auto mt-0 py-8 px-4 md:py-10 md:px-6">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
              <h1 class="text-xl md:text-3xl font-semibold tracking-tight text-gray-900 dark:text-white m-0">
                {providerLogos[provider] ? (
                  <div class="flex flex-col gap-3">
                    <div class="flex items-center gap-4">
                      <img src={providerLogos[provider]} alt={displayName} class="h-8 w-auto object-contain dark:hidden" />
                      <img src={providerLogosDark[provider] || providerLogos[provider]} alt="" class="h-8 w-auto mt-0 object-contain hidden dark:block" />
                    </div>
                    <span class="text-lg md:text-2xl">Storage Benchmarks</span>
                  </div>
                ) : (
                  <>{displayName} Storage Benchmarks</>
                )}
              </h1>
              {timestamp && (
                <p class="mt-3 text-sm text-gray-500 dark:text-gray-400">Last benchmarked {timestamp}</p>
              )}
            </div>
            <div class="pt-6 border-t md:border-0 md:pt-0 md:mt-0 border-gray-200/50 dark:border-gray-700/50">
              <SponsorLogos size="sm" layout="stacked" align="left" mdAlign="center" tier="tier-1" label="Sponsored by:" />
            </div>
          </div>
        </div>
      </div>
    </header>

    {fetchError || !result ? (
      <div class="max-w-4xl mx-auto my-0 py-16 text-center">
        <p class="text-gray-500 dark:text-gray-400">Benchmark data is currently unavailable. Please check back later.</p>
      </div>
    ) : (
      <StorageProviderDetailDashboard
        client:visible
        provider={provider}
        result={result}
        historyData={historyData}
      />
    )}

  </div>
  </PageLayout>
</StarlightPage>

<style is:global>
  .provider-nav-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .provider-nav-scroll::-webkit-scrollbar {
    display: none;
  }
</style>
