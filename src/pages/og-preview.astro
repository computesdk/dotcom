---
import {
  fetchLatestResults,
  fetchLatestStorageResults,
  fetchLatestBrowserResults,
  fetchLatestAIGatewayResults,
} from "../utils/benchmark-data";

const SANDBOX_TEST_TYPES = [
  { slug: "sequential-tti", label: "Sequential TTI" },
  { slug: "burst-tti",      label: "Burst TTI"       },
  { slug: "staggered-tti",  label: "Staggered TTI"   },
];

const FILE_SIZE = "10mb";

async function safeFetch<T>(fn: () => Promise<T[]>, fallback: string[]): Promise<string[]> {
  try {
    const results = await fn();
    return (results as any[]).map((r) => r.provider);
  } catch {
    return fallback;
  }
}

const sandboxProviders = await safeFetch(
  () => fetchLatestResults("sequential_tti"),
  ["e2b", "modal", "daytona", "vercel", "namespace", "blaxel", "codesandbox", "hopx", "runloop", "cloudflare"],
);
const storageProviders = await safeFetch(
  () => fetchLatestStorageResults(FILE_SIZE),
  ["aws-s3", "cloudflare-r2", "tigris", "azure-blob", "vercel-blob"],
);
const browserProviders = await safeFetch(
  () => fetchLatestBrowserResults(),
  ["browserbase", "kernel", "hyperbrowser", "steel", "tilion"],
);
const aiGatewayProviders = await safeFetch(
  () => fetchLatestAIGatewayResults(),
  ["openrouter", "vercel-ai-gateway", "cloudflare-ai-gateway", "llmgateway", "pydantic-ai-gateway", "anthropic-direct"],
);

interface Tab {
  id: string;
  label: string;
  leaderboardSrc: string;
  providers: string[];
  ogBase: string;
}

const tabs: Tab[] = [
  { id: "sandbox", label: "Sandbox", leaderboardSrc: "/benchmarks/sandboxes/og/index.png", providers: sandboxProviders, ogBase: "/benchmarks/sandboxes/og" },
  { id: "storage", label: "Storage", leaderboardSrc: "/benchmarks/storage/og/index.png", providers: storageProviders, ogBase: "/benchmarks/storage/og" },
  { id: "browser", label: "Browser", leaderboardSrc: "/benchmarks/browsers/og/index.png", providers: browserProviders, ogBase: "/benchmarks/browsers/og" },
  { id: "ai-gateway", label: "AI Gateway", leaderboardSrc: "/benchmarks/ai-gateway/og/index.png", providers: aiGatewayProviders, ogBase: "/benchmarks/ai-gateway/og" },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>OG Preview — ComputeSDK</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      margin: 0;
      background: #0a0a0f;
      color: #e2e8f0;
      font-family: system-ui, -apple-system, sans-serif;
      padding: 2rem;
    }
    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      margin: 0 0 0.25rem;
    }
    .subtitle {
      font-size: 0.875rem;
      color: #64748b;
      margin: 0 0 3rem;
    }
    section {
      margin-bottom: 3rem;
    }
    .section-label {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #64748b;
      margin: 0 0 0.75rem;
    }
    .provider-label {
      font-size: 1rem;
      font-weight: 600;
      text-transform: capitalize;
      margin: 0 0 1rem;
    }
    .card-label {
      font-size: 0.75rem;
      color: #94a3b8;
      margin: 0 0 0.5rem;
    }
    .og-img {
      display: block;
      width: 600px;
      max-width: 100%;
      height: auto;
      aspect-ratio: 1200 / 630;
      border-radius: 0.5rem;
      border: 1px solid #1e293b;
      transition: border-color 0.15s;
    }
    .og-img:hover {
      border-color: #3b82f6;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .divider {
      height: 1px;
      background: #1e293b;
      margin: 2rem 0 3rem;
    }
    .general-row {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
    }
    .tab-bar {
      display: flex;
      gap: 0.5rem;
      border-bottom: 1px solid #1e293b;
      margin-bottom: 2rem;
    }
    .tab-button {
      appearance: none;
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      color: #64748b;
      font: inherit;
      font-size: 0.875rem;
      font-weight: 600;
      padding: 0.75rem 0.25rem;
      margin-right: 1.5rem;
      cursor: pointer;
      transition: color 0.15s, border-color 0.15s;
    }
    .tab-button:hover {
      color: #e2e8f0;
    }
    .tab-button[aria-selected="true"] {
      color: #ffffff;
      border-bottom-color: #3b82f6;
    }
    .tab-panel {
      display: none;
    }
    .tab-panel[data-active="true"] {
      display: block;
    }
  </style>
</head>
<body>
  <h1>OG Image Preview</h1>
  <p class="subtitle">Non-indexed internal page. All OG images for computesdk.com.</p>

  <!-- Sitewide defaults -->
  <section>
    <p class="section-label">General</p>
    <div class="general-row">
      <div class="card">
        <p class="card-label">Default (All Starlight / Docs Pages)</p>
        <a href="/og-preview-image.png" target="_blank" rel="noopener noreferrer">
          <img src="/og-preview-image.png" width={1200} height={630} alt="Default OG" class="og-img" />
        </a>
      </div>
      <div class="card">
        <p class="card-label">Scale Invitational</p>
        <a href="/benchmarks/scale-invitational-og.png" target="_blank" rel="noopener noreferrer">
          <img src="/benchmarks/scale-invitational-og.png" width={1200} height={630} alt="Scale Invitational OG" class="og-img" />
        </a>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Benchmark categories -->
  <div class="tab-bar" role="tablist">
    {tabs.map((tab, i) => (
      <button
        class="tab-button"
        role="tab"
        type="button"
        data-tab-target={tab.id}
        aria-selected={i === 0 ? "true" : "false"}
      >
        {tab.label}
      </button>
    ))}
  </div>

  {tabs.map((tab, i) => (
    <div class="tab-panel" data-tab-panel={tab.id} data-active={i === 0 ? "true" : "false"}>
      <section>
        <p class="section-label">{tab.label} Benchmarks — Leaderboard</p>
        <a href={tab.leaderboardSrc} target="_blank" rel="noopener noreferrer">
          <img src={tab.leaderboardSrc} width={1200} height={630} alt={`${tab.label} leaderboard OG`} class="og-img" />
        </a>
      </section>

      <div class="divider"></div>

      {tab.providers.map((provider, idx) => (
        <section>
          <p class="provider-label">{provider}</p>

          {tab.id === "sandbox" ? (
            <>
              <div class="grid" style="margin-bottom: 1.5rem;">
                <div class="card">
                  <p class="card-label">All Test Types (Summary)</p>
                  <a href={`${tab.ogBase}/${provider}.png`} target="_blank" rel="noopener noreferrer">
                    <img src={`${tab.ogBase}/${provider}.png`} width={1200} height={630} alt={`${provider} summary OG`} class="og-img" />
                  </a>
                </div>
              </div>
              <div class="grid">
                {SANDBOX_TEST_TYPES.map(({ slug, label }) => (
                  <div class="card">
                    <p class="card-label">{label}</p>
                    <a href={`${tab.ogBase}/${provider}/${slug}.png`} target="_blank" rel="noopener noreferrer">
                      <img src={`${tab.ogBase}/${provider}/${slug}.png`} width={1200} height={630} alt={`${provider} ${label} OG`} class="og-img" />
                    </a>
                  </div>
                ))}
              </div>
            </>
          ) : (
            <div class="grid">
              <div class="card">
                <a href={`${tab.ogBase}/${provider}.png`} target="_blank" rel="noopener noreferrer">
                  <img src={`${tab.ogBase}/${provider}.png`} width={1200} height={630} alt={`${provider} OG`} class="og-img" />
                </a>
              </div>
            </div>
          )}

          {idx < tab.providers.length - 1 && <div class="divider" />}
        </section>
      ))}
    </div>
  ))}

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".tab-button");
    const panels = document.querySelectorAll<HTMLDivElement>(".tab-panel");
    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const target = button.dataset.tabTarget;
        buttons.forEach((b) => b.setAttribute("aria-selected", String(b === button)));
        panels.forEach((p) => p.setAttribute("data-active", String(p.dataset.tabPanel === target)));
      });
    });
  </script>
</body>
</html>
